# Public API base — must end with /api. Rebuild/redeploy frontend after changing.
# Local:
VITE_API_BASE_URL=http://localhost:5000/api
# Production (example):
# VITE_API_BASE_URL=https://your-api.vercel.app/api
#
# CORS: on the API host set FRONTEND_URL to the exact site origin users open
# (e.g. https://www.anandsandeshkaryalay.online). Mismatch causes browser "CORS" / "Failed to fetch".
