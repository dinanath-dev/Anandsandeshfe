# Public API base — must end with /api. Rebuild/redeploy frontend after changing.
# Local:
# VITE_API_BASE_URL=http://localhost:5000/api
# Production:
VITE_API_BASE_URL=https://api.anandsandeshkaryalay.online/api

# Razorpay recurring subscriptions — public key only (never KEY_SECRET on frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Plan IDs from Razorpay Dashboard → Subscriptions → Plans (interval: yearly)
VITE_RAZORPAY_PLAN_ID=
VITE_RAZORPAY_PLAN_ID_YEARLY=
VITE_RAZORPAY_PLAN_ID_FIVE_YEAR=
# total_count = yearly billing cycles (max ~94 — Razorpay end_time cap is 2120-12-31)
VITE_RAZORPAY_TOTAL_COUNT_YEARLY=94
VITE_RAZORPAY_TOTAL_COUNT_FIVE_YEAR=5
