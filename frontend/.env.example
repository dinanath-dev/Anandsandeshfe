# Public API base — must end with /api. Rebuild/redeploy frontend after changing.
# Local:
# VITE_API_BASE_URL=http://localhost:5000/api
# Production (also the fallback when the site runs on anandsandeshkaryalay.online):
VITE_API_BASE_URL=https://api.anandsandeshkaryalay.online/api

VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# 1-YEAR — Razorpay plan bills every 1 year
VITE_RAZORPAY_PLAN_ID_IN_1PUB=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_IN_2PUB=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_FOREIGN_1PUB=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_FOREIGN_2PUB=plan_xxxxxxxxxxxx
VITE_RAZORPAY_TOTAL_COUNT_YEARLY=10

# 5-YEAR — Razorpay plan bills every 5 years (interval = 5 years in dashboard)
VITE_RAZORPAY_PLAN_ID_IN_1PUB_FIVE=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_IN_2PUB_FIVE=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_FOREIGN_1PUB_FIVE=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ID_FOREIGN_2PUB_FIVE=plan_xxxxxxxxxxxx
VITE_RAZORPAY_TOTAL_COUNT_FIVE_YEAR=6

VITE_RAZORPAY_PLAN_ID=
VITE_RAZORPAY_PLAN_ID_YEARLY=
VITE_RAZORPAY_PLAN_ID_FIVE_YEAR=

VITE_ADMIN_PORTAL_ID=replace-with-a-random-portal-uuid
